{
  "info": {
    "name": "AutomationExercise API",
    "description": "Covers the 8 public endpoints / 14 documented scenarios listed at https://automationexercise.com/api_list",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Products & Brands",
      "item": [
        {
          "name": "Get All Products List",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('responseCode is 200', () => pm.expect(pm.response.json().responseCode).to.eql(200));",
                  "pm.test('products array is present', () => pm.expect(pm.response.json().products).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/productsList", "host": ["{{base_url}}"], "path": ["api", "productsList"] }
          }
        },
        {
          "name": "POST To All Products List (expect 405)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('responseCode is 405', () => pm.expect(pm.response.json().responseCode).to.eql(405));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/productsList", "host": ["{{base_url}}"], "path": ["api", "productsList"] }
          }
        },
        {
          "name": "Get All Brands List",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('brands array is present', () => pm.expect(pm.response.json().brands).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/brandsList", "host": ["{{base_url}}"], "path": ["api", "brandsList"] }
          }
        },
        {
          "name": "PUT To All Brands List (expect 405)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('responseCode is 405', () => pm.expect(pm.response.json().responseCode).to.eql(405));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": { "raw": "{{base_url}}/api/brandsList", "host": ["{{base_url}}"], "path": ["api", "brandsList"] }
          }
        }
      ]
    },
    {
      "name": "Search Product",
      "item": [
        {
          "name": "Search Product - valid keyword",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('responseCode is 200', () => pm.expect(pm.response.json().responseCode).to.eql(200));",
                  "pm.test('products array is present', () => pm.expect(pm.response.json().products).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/searchProduct", "host": ["{{base_url}}"], "path": ["api", "searchProduct"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [{ "key": "search_product", "value": "top" }]
            }
          }
        },
        {
          "name": "Search Product - missing parameter (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('responseCode is 400', () => pm.expect(pm.response.json().responseCode).to.eql(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/searchProduct", "host": ["{{base_url}}"], "path": ["api", "searchProduct"] }
          }
        }
      ]
    },
    {
      "name": "Login Verification",
      "item": [
        {
          "name": "Verify Login - valid details",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('responseCode is 200', () => pm.expect(pm.response.json().responseCode).to.eql(200));",
                  "pm.test('message is User exists!', () => pm.expect(pm.response.json().message).to.eql('User exists!'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/verifyLogin", "host": ["{{base_url}}"], "path": ["api", "verifyLogin"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email", "value": "{{qa_email}}" },
                { "key": "password", "value": "{{qa_password}}" }
              ]
            }
          }
        },
        {
          "name": "Verify Login - missing email (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('responseCode is 400', () => pm.expect(pm.response.json().responseCode).to.eql(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/verifyLogin", "host": ["{{base_url}}"], "path": ["api", "verifyLogin"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [{ "key": "password", "value": "{{qa_password}}" }]
            }
          }
        },
        {
          "name": "Verify Login - DELETE not supported (expect 405)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('responseCode is 405', () => pm.expect(pm.response.json().responseCode).to.eql(405));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/api/verifyLogin", "host": ["{{base_url}}"], "path": ["api", "verifyLogin"] }
          }
        },
        {
          "name": "Verify Login - invalid details (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('responseCode is 404', () => pm.expect(pm.response.json().responseCode).to.eql(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/verifyLogin", "host": ["{{base_url}}"], "path": ["api", "verifyLogin"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email", "value": "nonexistent.{{$timestamp}}@example.com" },
                { "key": "password", "value": "whatever" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Account Lifecycle",
      "item": [
        {
          "name": "1. Create Account",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('qa_email', 'qa.' + Date.now() + '@example.com');",
                  "pm.environment.set('qa_password', 'P@ssw0rd123');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('responseCode is 201', () => pm.expect(pm.response.json().responseCode).to.eql(201));",
                  "pm.test('message is User created!', () => pm.expect(pm.response.json().message).to.eql('User created!'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/createAccount", "host": ["{{base_url}}"], "path": ["api", "createAccount"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "QA Portfolio" },
                { "key": "email", "value": "{{qa_email}}" },
                { "key": "password", "value": "{{qa_password}}" },
                { "key": "title", "value": "Mr" },
                { "key": "birth_date", "value": "10" },
                { "key": "birth_month", "value": "5" },
                { "key": "birth_year", "value": "1995" },
                { "key": "firstname", "value": "QA" },
                { "key": "lastname", "value": "Portfolio" },
                { "key": "company", "value": "Portfolio Inc" },
                { "key": "address1", "value": "123 Test St" },
                { "key": "address2", "value": "" },
                { "key": "country", "value": "United States" },
                { "key": "zipcode", "value": "94107" },
                { "key": "state", "value": "CA" },
                { "key": "city", "value": "San Francisco" },
                { "key": "mobile_number", "value": "5555555555" }
              ]
            }
          }
        },
        {
          "name": "2. Get User Detail By Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('email matches created account', () => pm.expect(pm.response.json().user.email).to.eql(pm.environment.get('qa_email')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/getUserDetailByEmail?email={{qa_email}}",
              "host": ["{{base_url}}"],
              "path": ["api", "getUserDetailByEmail"],
              "query": [{ "key": "email", "value": "{{qa_email}}" }]
            }
          }
        },
        {
          "name": "3. Update Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('responseCode is 200', () => pm.expect(pm.response.json().responseCode).to.eql(200));",
                  "pm.test('message is User updated!', () => pm.expect(pm.response.json().message).to.eql('User updated!'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": { "raw": "{{base_url}}/api/updateAccount", "host": ["{{base_url}}"], "path": ["api", "updateAccount"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "QA Portfolio Updated" },
                { "key": "email", "value": "{{qa_email}}" },
                { "key": "password", "value": "{{qa_password}}" },
                { "key": "title", "value": "Mrs" },
                { "key": "birth_date", "value": "10" },
                { "key": "birth_month", "value": "5" },
                { "key": "birth_year", "value": "1995" },
                { "key": "firstname", "value": "QA" },
                { "key": "lastname", "value": "Portfolio" },
                { "key": "company", "value": "Portfolio Inc" },
                { "key": "address1", "value": "123 Test St" },
                { "key": "address2", "value": "" },
                { "key": "country", "value": "United States" },
                { "key": "zipcode", "value": "94107" },
                { "key": "state", "value": "CA" },
                { "key": "city", "value": "San Francisco" },
                { "key": "mobile_number", "value": "5555555555" }
              ]
            }
          }
        },
        {
          "name": "4. Delete Account (teardown)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('responseCode is 200', () => pm.expect(pm.response.json().responseCode).to.eql(200));",
                  "pm.test('message is Account deleted!', () => pm.expect(pm.response.json().message).to.eql('Account deleted!'));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/api/deleteAccount", "host": ["{{base_url}}"], "path": ["api", "deleteAccount"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email", "value": "{{qa_email}}" },
                { "key": "password", "value": "{{qa_password}}" }
              ]
            }
          }
        }
      ]
    }
  ]
}
