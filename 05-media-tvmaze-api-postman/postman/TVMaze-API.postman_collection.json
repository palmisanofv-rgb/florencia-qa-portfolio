{
  "info": {
    "name": "TVMaze API",
    "description": "Public, keyless TV catalog API - used as the streaming/media vertical of this portfolio",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Search Shows - valid query",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
          "const body = pm.response.json();",
          "pm.test('returns at least one result', () => pm.expect(body.length).to.be.above(0));",
          "pm.test('top result is Breaking Bad', () => pm.expect(body[0].show.name).to.eql('Breaking Bad'));",
          "pm.test('every result has a positive score', () => body.forEach(r => pm.expect(r.score).to.be.above(0)));"
        ]}
      }],
      "request": {
        "method": "GET",
        "url": {
          "raw": "https://api.tvmaze.com/search/shows?q=breaking bad",
          "host": ["api", "tvmaze", "com"],
          "path": ["search", "shows"],
          "query": [{ "key": "q", "value": "breaking bad" }]
        }
      }
    },
    {
      "name": "Get Show By ID",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
          "const body = pm.response.json();",
          "pm.test('id matches request', () => pm.expect(body.id).to.eql(169));",
          "pm.test('premiered matches date format', () => pm.expect(body.premiered).to.match(/^\\d{4}-\\d{2}-\\d{2}$/));",
          "pm.test('rating.average is a number or null', () => { const avg = body.rating.average; pm.expect(avg === null || typeof avg === 'number').to.be.true; });"
        ]}
      }],
      "request": {
        "method": "GET",
        "url": { "raw": "https://api.tvmaze.com/shows/169", "host": ["api", "tvmaze", "com"], "path": ["shows", "169"] }
      }
    },
    {
      "name": "Get Show By ID - nonexistent (expect 404)",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status code is 404', () => pm.response.to.have.status(404));"
        ]}
      }],
      "request": {
        "method": "GET",
        "url": { "raw": "https://api.tvmaze.com/shows/999999999", "host": ["api", "tvmaze", "com"], "path": ["shows", "999999999"] }
      }
    },
    {
      "name": "Get Episodes For Show",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
          "const episodes = pm.response.json();",
          "pm.test('episode list is not empty', () => pm.expect(episodes.length).to.be.above(0));",
          "pm.test('episodes are ordered by season then number', () => {",
          "  for (let i = 1; i < episodes.length; i++) {",
          "    const prev = episodes[i - 1]; const cur = episodes[i];",
          "    const prevKey = prev.season * 1000 + prev.number;",
          "    const curKey = cur.season * 1000 + cur.number;",
          "    pm.expect(curKey).to.be.at.least(prevKey);",
          "  }",
          "});"
        ]}
      }],
      "request": {
        "method": "GET",
        "url": { "raw": "https://api.tvmaze.com/shows/169/episodes", "host": ["api", "tvmaze", "com"], "path": ["shows", "169", "episodes"] }
      }
    },
    {
      "name": "Search People",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
          "const body = pm.response.json();",
          "pm.test('finds Bryan Cranston', () => pm.expect(body.some(r => r.person.name === 'Bryan Cranston')).to.be.true);"
        ]}
      }],
      "request": {
        "method": "GET",
        "url": {
          "raw": "https://api.tvmaze.com/search/people?q=bryan cranston",
          "host": ["api", "tvmaze", "com"],
          "path": ["search", "people"],
          "query": [{ "key": "q", "value": "bryan cranston" }]
        }
      }
    },
    {
      "name": "Schedule By Country And Date",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
          "const body = pm.response.json();",
          "pm.test('response is an array', () => pm.expect(body).to.be.an('array'));",
          "pm.test('response is not empty', () => pm.expect(body.length).to.be.above(0));",
          "pm.test('every entry airdate is within 1 day of the requested date', () => {",
          "  const requested = new Date('2024-01-01');",
          "  body.forEach(e => {",
          "    const diffDays = Math.abs((new Date(e.airdate) - requested) / 86400000);",
          "    pm.expect(diffDays).to.be.at.most(1);",
          "  });",
          "});",
          "pm.test('at least 95% of entries match the exact requested date (known TVMaze boundary quirk otherwise)', () => {",
          "  const exact = body.filter(e => e.airdate === '2024-01-01').length;",
          "  pm.expect(exact / body.length).to.be.at.least(0.95);",
          "});"
        ]}
      }],
      "request": {
        "method": "GET",
        "url": {
          "raw": "https://api.tvmaze.com/schedule?country=US&date=2024-01-01",
          "host": ["api", "tvmaze", "com"],
          "path": ["schedule"],
          "query": [{ "key": "country", "value": "US" }, { "key": "date", "value": "2024-01-01" }]
        }
      }
    }
  ]
}
