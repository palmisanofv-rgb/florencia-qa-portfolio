<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- Sequential on purpose: parallel="methods" made every @Test method in a class share
     one TestNG instance (and therefore one `driver` field) across threads, which caused
     a real, reproducible bug - two threads typing into the same login form at once
     (confirmed via a saved screenshot showing "standard_userstandard_user" in the
     username field). Fixing that properly means a ThreadLocal<WebDriver>; sequential
     execution is the safe, immediate fix for a suite this size. -->
<suite name="SwagLabsSuite">
  <test name="Login and Checkout">
    <classes>
      <class name="tests.LoginTests"/>
      <class name="tests.CheckoutTests"/>
    </classes>
  </test>
</suite>
